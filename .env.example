# Passwords for Web UI dashboard security
DASHBOARD_PASSWORD=your_dashboard_password_here
CONFIG_PASSWORD=your_config_password_here

# Credentials to access investir.lesechos.fr (scraped website)
INVESTIR_USERNAME=your_username@email.com
INVESTIR_PASSWORD=your_password_here

# E-mail alert recipient
EMAIL_RECIPIENT=recipient@email.com

# SMTP Server configuration for sending alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_auth_user@gmail.com
SMTP_PASS=your_smtp_app_password_here
SMTP_FROM=Alertes Investeer <your_smtp_auth_user@gmail.com>
